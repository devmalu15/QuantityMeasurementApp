{
  "Routes": [

    {
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "POST" ],
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        { "Host": "auth-service.runasp.net", "Port": 443 }
      ]
    },

    {
      "UpstreamPathTemplate": "/api/quantity/{everything}",
      "UpstreamHttpMethod": [ "POST" ],
      "DownstreamPathTemplate": "/api/quantity/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        { "Host": "operation-service.runasp.net", "Port": 443 }
      ]
    },

    {
      "UpstreamPathTemplate": "/api/quantity/history/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/api/quantity/history/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        { "Host": "history-service.runasp.net", "Port": 443 }
      ]
    }

  ],

  "GlobalConfiguration": {
    "BaseUrl": "https://ocelot-gateway.runasp.net"
  }
}